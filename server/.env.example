# Copy this file to .env and fill in your values
# Never commit .env to source control

PORT=5000
NODE_ENV=development

# MongoDB Atlas
# Get from: https://cloud.mongodb.com → Clusters → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/book-a-doctor?retryWrites=true&w=majority

# JWT
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string_minimum_32_chars
JWT_EXPIRE=7d

# Nodemailer — Gmail with App Password
# Enable 2FA on Gmail, then generate App Password at: myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password

# Frontend URL (used for CORS and email links)
# Development:
CLIENT_URL=http://localhost:5173
# Production (multiple origins supported, comma-separated):
# CLIENT_URL=https://book-a-doctor.vercel.app,https://www.book-a-doctor.vercel.app
